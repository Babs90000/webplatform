{
  "name": "webplatform-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "imports": {
    "#tailwind-reference": "./src/styles/tailwind-reference.css"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "tsx scripts/run-e2e-prod.ts",
    "test:e2e:ui": "tsx scripts/run-e2e-prod.ts -- --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:mobile": "tsx scripts/run-e2e-prod.ts -- --project=mobile",
    "test:e2e:tablet": "tsx scripts/run-e2e-prod.ts -- --project=tablet",
    "test:e2e:desktop": "tsx scripts/run-e2e-prod.ts -- --project=desktop",
    "test:e2e:a11y": "tsx scripts/run-e2e-prod.ts -- e2e/app-a11y.spec.ts e2e/generated-site-a11y.spec.ts --workers=1",
    "test:e2e:smoke": "tsx scripts/run-e2e-prod.ts -- e2e/live-smoke.spec.ts e2e/committee-quality.spec.ts --workers=1",
    "test:e2e:committee": "tsx scripts/run-e2e-prod.ts -- e2e/committee-quality.spec.ts --workers=1",
    "test:e2e:mock": "tsx scripts/run-e2e-fixtures.ts",
    "test:e2e:prod": "tsx scripts/run-e2e-prod.ts",
    "compare:project-fixture": "tsx scripts/compare-project-fixture.ts",
    "test:all": "pnpm test:unit && pnpm test:e2e",
    "test:ci": "pnpm test:unit",
    "export:project-fixture": "tsx scripts/export-project-fixture.ts",
    "export:all-fixtures": "tsx scripts/export-all-fixtures.ts",
    "export:fixtures:discover": "tsx scripts/export-all-fixtures.ts -- --discover"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.3.4",
    "@tanstack/react-query": "^5.100.14",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.6",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.51.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^15.0.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^1.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^24.0.0",
    "msw": "^2.1.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vitest": "^1.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "msw"
    ]
  }
}

# Tests E2E production — automatisable (Coolify ou local)
# cp .env.e2e.example .env.e2e.local

E2E_PROD_APP_URL=https://webplatform.kdevs.io
E2E_PROD_API_URL=https://api.webplatform.kdevs.io/api/v1

# --- Option A : automatique (recommandé Coolify) ---
# Compte dédié + projet nommé « e2e » ou slug contenant « e2e »
E2E_FIXTURE_EMAIL=
E2E_FIXTURE_PASSWORD=
E2E_PROJECT_NAME_HINT=e2e

# --- Option B : manuel (DevTools) ---
# WEBPLATFORM_TOKEN=
# E2E_LIVE_PROJECT_ID=

# Lancer : pnpm test:e2e  |  smoke+comité : pnpm test:e2e:smoke
# La revue IA (6 experts) tourne déjà à la génération/audit dans le studio.
# E2E = garde-fous sur les mêmes axes (DA, UX, Réd, SEO, CRO, A11y).
